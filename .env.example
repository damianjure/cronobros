# Public Firebase Web SDK configuration. These values identify the Firebase
# app but do not grant database access; Auth and Firestore Rules enforce it.
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
# Optional until a reCAPTCHA Enterprise provider is registered in Firebase
# App Check. Configure the client first, then enable callable enforcement.
VITE_FIREBASE_APP_CHECK_SITE_KEY=your-recaptcha-enterprise-site-key

# Public browser key restricted by HTTP referrer. Enable Maps JavaScript API
# and Routes API in the same Google Cloud project.
VITE_GOOGLE_MAPS_API_KEY=your-restricted-browser-key
VITE_GOOGLE_MAP_ID=your-map-id
